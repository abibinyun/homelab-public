# =============================================================
# DEPLOYER .env — Konfigurasi aplikasi deployer
# Digunakan oleh: projects/deployer/ (backend + frontend)
# Cara setup: jalankan ./scripts/setup.sh atau ./scripts/setup-demo.sh
# JANGAN edit manual kecuali kamu tahu apa yang dilakukan
# =============================================================

# -------------------------------------------------------------
# [WAJIB] Credentials login ke Deployer UI
# ADMIN_PASSWORD wajib diisi — app tidak akan start jika kosong
# -------------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password   # Min 6 karakter, WAJIB diisi
ADMIN_EMAIL=admin@yourdomain.com      # Opsional, default: admin@localhost

# -------------------------------------------------------------
# [WAJIB] Konfigurasi app
# -------------------------------------------------------------
NODE_ENV=production
PORT=3000
DOMAIN=yourdomain.com       # Sama dengan DOMAIN di .env root
VITE_DOMAIN=yourdomain.com  # Sama dengan DOMAIN di .env root

# -------------------------------------------------------------
# [OPSIONAL] Demo mode
# true  = UI preview only, semua action di-disable
# false = Mode normal (production)
# -------------------------------------------------------------
DEMO_MODE=false

# -------------------------------------------------------------
# [OPSIONAL] Database PostgreSQL
# Kosongkan jika tidak punya PostgreSQL → otomatis pakai JSON file
# Nilai POSTGRES_PASSWORD harus sama dengan di .env root
# -------------------------------------------------------------
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@postgres:5432/deployer

# -------------------------------------------------------------
# [OPSIONAL] Redis
# Kosongkan jika tidak punya Redis → otomatis pakai in-memory session
# Nilai REDIS_PASSWORD harus sama dengan di .env root
# -------------------------------------------------------------
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379

# -------------------------------------------------------------
# [WAJIB] Auth secrets — generate dengan: openssl rand -hex 32
# JANGAN gunakan nilai default ini di production!
# -------------------------------------------------------------
JWT_SECRET=
SESSION_SECRET=
ENCRYPTION_KEY=

# -------------------------------------------------------------
# [OPSIONAL] Internal webhook token
# Digunakan untuk internal self-call saat trigger deploy via webhook
# Generate: openssl rand -hex 16
# -------------------------------------------------------------
INTERNAL_WEBHOOK_TOKEN=

# -------------------------------------------------------------
# [JANGAN DIUBAH] Path internal Docker
# -------------------------------------------------------------
SSH_KEY_PATH=/root/.ssh/id_ed25519.pub
HOMELAB_PATH=/homelab
DOCKER_NETWORK=homelab-public_web

# -------------------------------------------------------------
# [OPSIONAL] Batas jumlah project
# 0 atau kosong = tidak ada batas
# Contoh: MAX_PROJECTS=5 → maksimal 5 project
# -------------------------------------------------------------
MAX_PROJECTS=

# -------------------------------------------------------------
# [OPSIONAL] Cloudflare API
# Digunakan untuk auto-routing subdomain saat deploy project baru
# Tanpa ini, subdomain tidak akan otomatis terbuat
# Sama dengan nilai di .env root
# -------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
