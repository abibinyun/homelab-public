# =============================================================
# DEPLOYER .env — Deployer application configuration
# Used by: projects/deployer/ (backend + frontend)
# Setup: run ./scripts/setup.sh or ./scripts/setup-demo.sh
# Do NOT edit manually unless you know what you are doing
# =============================================================

# -------------------------------------------------------------
# [REQUIRED] Deployer UI login credentials
# ADMIN_PASSWORD is required — app will not start if empty
# -------------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password   # Min 6 characters, REQUIRED
ADMIN_EMAIL=admin@yourdomain.com      # Optional, default: admin@localhost

# -------------------------------------------------------------
# [REQUIRED] App configuration
# -------------------------------------------------------------
NODE_ENV=production
PORT=3000
DOMAIN=yourdomain.com       # Must match DOMAIN in root .env
VITE_DOMAIN=yourdomain.com  # Must match DOMAIN in root .env

# -------------------------------------------------------------
# [OPTIONAL] Demo mode
# true  = UI preview only, all actions disabled
# false = Normal mode (production)
# -------------------------------------------------------------
DEMO_MODE=false

# -------------------------------------------------------------
# [OPTIONAL] PostgreSQL Database
# Leave empty if no PostgreSQL → automatically uses JSON file
# POSTGRES_PASSWORD must match the value in root .env
# -------------------------------------------------------------
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@postgres:5432/deployer

# -------------------------------------------------------------
# [OPTIONAL] Redis
# Leave empty if no Redis → automatically uses in-memory session
# REDIS_PASSWORD must match the value in root .env
# -------------------------------------------------------------
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379

# -------------------------------------------------------------
# [REQUIRED] Auth secrets — generate with: openssl rand -hex 32
# Do NOT use default values in production!
# -------------------------------------------------------------
JWT_SECRET=
SESSION_SECRET=
ENCRYPTION_KEY=

# -------------------------------------------------------------
# [OPTIONAL] Internal webhook token
# Used for internal self-call when triggering deploy via webhook
# Generate: openssl rand -hex 16
# -------------------------------------------------------------
INTERNAL_WEBHOOK_TOKEN=

# -------------------------------------------------------------
# [DO NOT CHANGE] Internal Docker paths
# -------------------------------------------------------------
SSH_KEY_PATH=/root/.ssh/id_ed25519.pub
HOMELAB_PATH=/homelab
DOCKER_NETWORK=homelab-public_web

# -------------------------------------------------------------
# [OPTIONAL] Project limit
# 0 or empty = no limit
# Example: MAX_PROJECTS=5 → maximum 5 projects
# -------------------------------------------------------------
MAX_PROJECTS=

# -------------------------------------------------------------
# [OPTIONAL] Cloudflare API
# Used for auto-routing subdomains when deploying new projects
# Without this, subdomains will not be created automatically
# Must match values in root .env
# -------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
