# =============================================================
# ROOT .env — Konfigurasi infrastruktur (Traefik, DB, Redis)
# Digunakan oleh: docker-compose.yml
# Cara setup: jalankan ./scripts/setup.sh (auto-generate semua)
# =============================================================

# Domain utama kamu (tanpa subdomain)
# Contoh: example.com → deployer akan jalan di deploy.example.com
DOMAIN=yourdomain.com

# Cloudflare Tunnel Token — WAJIB untuk full setup
# Cara dapat: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create tunnel
TUNNEL_TOKEN=your_tunnel_token_here

# Traefik Dashboard Auth — WAJIB
# Cara generate: docker run --rm httpd:alpine htpasswd -nb admin passwordkamu
# Ganti $ dengan $$ di docker-compose
TRAEFIK_AUTH=admin:$$apr1$$xyz...

# Database PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti-dengan-password-kuat   # WAJIB diganti sebelum production!
POSTGRES_DB=deployer

# Redis
REDIS_PASSWORD=ganti-dengan-password-kuat      # WAJIB diganti sebelum production!

# Port deployer (default 3000, ubah jika konflik)
PORT=3000

# =============================================================
# Cloudflare API — OPSIONAL
# Digunakan untuk auto-routing subdomain per project yang di-deploy
# Tanpa ini, kamu harus tambah DNS record manual di Cloudflare
# Cara dapat token: https://dash.cloudflare.com/profile/api-tokens
# Permissions yang dibutuhkan: Zone.DNS (Edit), Zone.Zone (Read),
#                              Account.Cloudflare Tunnel (Edit)
# =============================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_ID=
