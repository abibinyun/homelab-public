# =============================================================
# ROOT .env — Infrastructure configuration (Traefik, DB, Redis)
# Used by: docker-compose.yml
# Setup: run ./scripts/setup.sh (auto-generates everything)
# =============================================================

# Your primary domain (without subdomain)
# Example: example.com → deployer will run at deploy.example.com
DOMAIN=yourdomain.com

# Cloudflare Tunnel Token — REQUIRED for full setup
# How to get: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create tunnel
TUNNEL_TOKEN=your_tunnel_token_here

# Traefik Dashboard Auth — REQUIRED
# Generate with: docker run --rm httpd:alpine htpasswd -nb admin yourpassword
# Replace $ with $$ in docker-compose
TRAEFIK_AUTH=admin:$$apr1$$xyz...

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-to-strong-password   # REQUIRED — change before production!
POSTGRES_DB=deployer

# Redis
REDIS_PASSWORD=change-to-strong-password      # REQUIRED — change before production!

# Deployer port (default 3000, change if conflict)
PORT=3000

# =============================================================
# Cloudflare API — OPTIONAL
# Used for auto-routing subdomains when deploying new projects
# Without this, you must add DNS records manually in Cloudflare
# Get token: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone.DNS (Edit), Zone.Zone (Read),
#                       Account.Cloudflare Tunnel (Edit)
# =============================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_ID=
